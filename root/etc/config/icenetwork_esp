config core 'main'
    option enabled '1'
    option server '192.168.1.2'
    option port '9000'
    option esp_path '/metrics'
    option auth_mode 'none'
    option auth_token ''
    option auth_header_name 'X-Auth-Token'
    option hmac_secret ''
    option hmac_header_name 'X-Signature'
    option hmac_timestamp_header 'X-Timestamp'
    option check_interval '60'
    option ping_target '8.8.8.8'
    option ping_count '4'
    option ping_timeout '2'
    option timeout_loss_threshold '100'
    option timeout_command ''
    option speedtest_enabled '1'
    option speedtest_url 'http://speed.cloudflare.com/__down?bytes=5000000'
    option speedtest_timeout '15'
    option speedtest_interval '300'
    option ua3f_autostart '1'
    option ua3f_service 'ua3f'
